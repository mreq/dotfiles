{
  "rpm-ostree": {
    "remove": [
      { "package": "firefox", "info": "Replaced by distrobox Firefox" },
      { "package": "firefox-langpacks", "info": "Depends on firefox; must be removed in the same transaction" }
    ],
    "install": [
      { "package": "distrobox", "info": "Run any Linux distro in a container" },
      { "package": "tmux", "info": "Terminal multiplexer" },
      { "package": "btop", "info": "Resource monitor" },
      { "package": "ripgrep", "info": "Fast recursive grep" },
      { "package": "python3-i3ipc", "info": "Python sway IPC for bin/sway/ scripts" },
      { "package": "openssh-askpass", "info": "SSH passphrase GUI prompt" }
    ]
  },
  "distrobox": {
    "apps": {
      "image": "registry.fedoraproject.org/fedora-toolbox:latest",
      "packages": [
        {
          "package": "google-chrome-stable",
          "info": "Web browser",
          "requires-package": "fedora-workstation-repositories",
          "enable-repo": "google-chrome"
        },
        {
          "package": "slack",
          "info": "Team messaging — RPM URL scraped from slack.com (no vendor repo)",
          "url-from-page": "https://slack.com/downloads/instructions/linux?ddl=1&build=rpm",
          "url-pattern": "https://downloads\\.slack-edge\\.com/[^\"' ]+\\.rpm"
        },
        {
          "package": "sublime-text",
          "info": "Text editor",
          "gpg-key": "https://download.sublimetext.com/sublimehq-rpm-pub.gpg",
          "repofile": "https://download.sublimetext.com/rpm/stable/x86_64/sublime-text.repo"
        },
        { "package": "keepassxc", "info": "Password manager" },
        { "package": "firefox", "info": "Web browser" },
        { "package": "thunderbird", "info": "Email client" },
        {
          "package": "doublecmd-qt",
          "info": "Twin-panel file manager (Qt5 build, native Wayland)",
          "requires-package": "qt5-qtwayland"
        }
      ],
      "export-apps": [
        "google-chrome-stable",
        "slack",
        "sublime_text",
        "keepassxc",
        "firefox",
        "thunderbird",
        "doublecmd-qt"
      ]
    },
    "dev": {
      "image": "registry.fedoraproject.org/fedora-toolbox:latest",
      "packages": [
        { "package": "gh", "info": "GitHub CLI" },
        { "package": "awscli2", "info": "AWS CLI v2" },
        { "package": "wf-recorder", "info": "Wayland screen recorder" }
      ],
      "export-bins": [
        "/usr/bin/gh",
        "/usr/bin/aws",
        "/usr/bin/wf-recorder"
      ]
    }
  },
  "flatpak": [
    { "package": "com.spotify.Client", "info": "Music streaming" },
    { "package": "org.gimp.GIMP", "info": "Image editor" }
  ],
  "appimage": [
    {
      "name": "cursor",
      "info": "AI code editor",
      "source": "manual",
      "file-pattern": "Cursor-*.AppImage",
      "install-dir": "~/.local/share/cursor"
    },
    {
      "name": "freelens",
      "info": "Kubernetes IDE",
      "source": "github",
      "repo": "freelensapp/freelens",
      "asset-pattern": "Freelens-*.x86_64.AppImage",
      "install-dir": "~/.local/share/freelens"
    }
  ],
  "binary": [
    {
      "name": "lazygit",
      "info": "Terminal UI for git",
      "source": "github",
      "repo": "jesseduffield/lazygit",
      "asset-pattern": "lazygit_*_Linux_x86_64.tar.gz",
      "install-path": "~/.local/bin/lazygit"
    }
  ],
  "systemd-user": {
    "enable": [
      "ssh-agent.socket",
      "podman.socket"
    ],
    "enable-custom": [
      { "service": "dropbox.service", "info": "Dropbox file sync daemon" },
      { "service": "wlsunset.service", "info": "Day/night color temperature" }
    ]
  }
}
