#!/usr/bin/env python3
import sys
from pathlib import Path

import i3ipc

sys.path.append(str(Path(__file__).resolve().parents[2] / "python/modules"))
import dotfiles  # noqa: E402

sway = i3ipc.Connection()

result = dotfiles.rofi.prompt()

if result:
    sway.command("rename workspace to '" + result + "'")
