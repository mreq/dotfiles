#!/usr/bin/env python3
import i3ipc
import os, sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), '..', '..', 'python', 'modules'))
import dotfiles

sway = i3ipc.Connection()

tree = sway.get_tree()

focused = tree.find_focused()
focused_workspace = focused.workspace()

result = dotfiles.rofi.prompt()

if result:
    sway.command("rename workspace to '" + result + "'")
