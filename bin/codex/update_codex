#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
CONFIG_PATH="${CODEX_UPDATE_CONFIG:-$DOTFILES_DIR/config/codex/release.json}"

ASSET="codex-x86_64-unknown-linux-musl.tar.gz"
BINARY="codex-x86_64-unknown-linux-musl"
INSTALL_PATH="$HOME/.local/bin/codex"
RELEASES_URL="https://github.com/openai/codex/releases"
LATEST_RELEASE_API_URL="https://api.github.com/repos/openai/codex/releases/latest"

log() {
	echo "update_codex - $*"
}

error() {
	log "ERROR: $*" >&2
	exit 1
}

require_command() {
	if ! command -v "$1" >/dev/null 2>&1; then
		error "Missing required command: $1"
	fi
}

usage() {
	cat <<EOF
Usage: update_codex [--open-releases | --update-release-config]

Options:
  --open-releases          Open the Codex GitHub releases page in the browser.
  --update-release-config  Fetch the latest stable release and update release.json.
  -h, --help               Show this help.
EOF
}

require_linux_x86_64() {
	local os
	local arch

	os="$(uname -s)"
	arch="$(uname -m)"

	if [[ "$os" != "Linux" || "$arch" != "x86_64" ]]; then
		error "Unsupported platform: $os $arch. Expected Linux x86_64."
	fi
}

read_config_value() {
	local key=$1
	jq -r ".$key // empty" "$CONFIG_PATH"
}

confirm() {
	local prompt=$1
	local answer

	while true; do
		read -r -p "$prompt [Y/n] " answer

		case "$answer" in
		"" | [Yy] | [Yy][Ee][Ss])
			return 0
			;;
		[Nn] | [Nn][Oo])
			return 1
			;;
		*)
			log "Please answer y or n."
			;;
		esac
	done
}

fetch_latest_release_json() {
	curl --fail --location --show-error --silent \
		--header "Accept: application/vnd.github+json" \
		"$LATEST_RELEASE_API_URL"
}

latest_release_value() {
	local release_json=$1
	local filter=$2

	jq -r "$filter // empty" <<<"$release_json"
}

update_release_config() {
	local release_json
	local release_tag
	local asset_digest
	local new_config

	require_command curl
	require_command jq

	log "Fetching latest stable Codex release"
	release_json="$(fetch_latest_release_json)"
	release_tag="$(latest_release_value "$release_json" ".tag_name")"

	if [[ -z "$release_tag" ]]; then
		error "GitHub response did not include a release tag."
	fi

	asset_digest="$(
		jq -r --arg asset "$ASSET" \
			'first(.assets[]? | select(.name == $asset)) // {} | .digest // empty' \
			<<<"$release_json"
	)"

	if [[ ! "$asset_digest" =~ ^sha256:[0-9a-fA-F]{64}$ ]]; then
		error "GitHub did not provide a valid SHA-256 digest for $ASSET in $release_tag."
	fi

	new_config="$(
		jq -n \
			--arg release_tag "$release_tag" \
			--arg sha256 "$asset_digest" \
			'{ release_tag: $release_tag, sha256: $sha256 }'
	)"

	log "New release config:"
	printf '%s\n' "$new_config"

	if confirm "Write $CONFIG_PATH?"; then
		printf '%s\n' "$new_config" >"$CONFIG_PATH"
		log "Updated $CONFIG_PATH"
	else
		log "Skipped writing $CONFIG_PATH"
	fi
}

case "${1:-}" in
--open-releases)
	require_command xdg-open
	xdg-open "$RELEASES_URL"
	exit 0
	;;
--update-release-config)
	update_release_config
	exit 0
	;;
-h | --help)
	usage
	exit 0
	;;
"") ;;
*)
	usage >&2
	error "Unknown option: $1"
	;;
esac

require_command curl
require_command install
require_command jq
require_command sha256sum
require_command tar

require_linux_x86_64

if [[ ! -f "$CONFIG_PATH" ]]; then
	error "Missing config: $CONFIG_PATH"
fi

CODEX_RELEASE_TAG="$(read_config_value release_tag)"
CODEX_SHA256="$(read_config_value sha256)"

if [[ -z "$CODEX_RELEASE_TAG" ]]; then
	error "Missing release_tag in $CONFIG_PATH"
fi

if [[ ! "$CODEX_SHA256" =~ ^sha256:[0-9a-fA-F]{64}$ ]]; then
	error "Invalid sha256 in $CONFIG_PATH. Expected sha256:<64_hex_sha256>."
fi

DOWNLOAD_URL="https://github.com/openai/codex/releases/download/$CODEX_RELEASE_TAG/$ASSET"
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

ARCHIVE_PATH="$TMP_DIR/$ASSET"

log "Downloading $ASSET from $CODEX_RELEASE_TAG"
curl --fail --location --show-error --silent \
	--output "$ARCHIVE_PATH" \
	"$DOWNLOAD_URL"

log "Verifying SHA-256"
printf '%s  %s\n' "${CODEX_SHA256#sha256:}" "$ARCHIVE_PATH" | sha256sum --check --strict

log "Extracting $BINARY"
tar -xzf "$ARCHIVE_PATH" -C "$TMP_DIR"

if [[ ! -f "$TMP_DIR/$BINARY" ]]; then
	error "Release archive did not contain $BINARY"
fi

log "Installing to $INSTALL_PATH"
mkdir -p "$(dirname "$INSTALL_PATH")"
install -m 0755 "$TMP_DIR/$BINARY" "$INSTALL_PATH"

RESOLVED_CODEX="$(command -v codex || true)"
if [[ "$RESOLVED_CODEX" != "$INSTALL_PATH" ]]; then
	log "WARNING: PATH resolves codex to ${RESOLVED_CODEX:-nothing}, not $INSTALL_PATH"
fi

log "Installed Codex $CODEX_RELEASE_TAG"
log $'\033[32mDone\033[0m'
