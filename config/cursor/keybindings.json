[
  // --- General ---
  { "key": "ctrl+i", "command": "composerMode.agent" },
  { "key": "ctrl+p", "command": "workbench.action.quickOpenSelectPrevious", "when": "inQuickOpen || quickInputVisible" },
  { "key": "ctrl+n", "command": "workbench.action.quickOpenSelectNext", "when": "inQuickOpen || quickInputVisible" },
  { "key": "ctrl+tab", "command": "workbench.action.nextEditorInGroup" },
  { "key": "ctrl+shift+tab", "command": "workbench.action.previousEditorInGroup" },
  { "key": "alt+l", "command": "workbench.action.focusNextGroup" },
  { "key": "alt+h", "command": "workbench.action.focusPreviousGroup" },
  { "key": "alt+shift+l", "command": "workbench.action.moveEditorToRightGroup" },
  { "key": "alt+shift+h", "command": "workbench.action.moveEditorToLeftGroup" },
  { "key": "ctrl+r", "command": "workbench.action.gotoSymbol" },
  {
    "key": "ctrl+space",
    "command": "filehop.hop",
    "args": { "slot": "alpha" },
    "when": "editorTextFocus && vim.mode == 'Normal'"
  },
  {
    "key": "ctrl+backspace",
    "command": "filehop.hop",
    "args": { "slot": "delta" },
    "when": "editorTextFocus && vim.mode == 'Normal'"
  },
  {
    "key": "ctrl+shift+space",
    "command": "filehop.hop",
    "args": { "slot": "beta" },
    "when": "editorTextFocus && vim.mode == 'Normal'"
  },
  {
    "key": "ctrl+shift+alt+space",
    "command": "filehop.hop",
    "args": { "slot": "gamma" },
    "when": "editorTextFocus && vim.mode == 'Normal'"
  },
  {
    "key": "space i",
    "command": "abut.open",
    "when": "editorTextFocus && vim.mode == 'Normal'"
  }
]
